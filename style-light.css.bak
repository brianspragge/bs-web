/* ThinkPad white / light mode — still built like a tank */

:root {
  --bg:        #f8f8f8;       /* clean off-white chassis */
  --surface:   #ffffff;       /* pure panel / palmrest white */
  --text:      #1a1a1a;       /* near-black for max readability */
  --text-dim:  #606060;       /* secondary / muted text */
  --accent:    #e6392d;       /* TrackPoint red — unchanged */
  --border:    #c0c0c0;       /* light but visible ThinkPad edge */
  --highlight: #ff4d4d;       /* brighter red on hover */
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  background: var(--bg);
  color: var(--text);
  font-family: "Lucida Console", "Courier New", "DejaVu Sans Mono", monospace;
  font-size: 16px;
  line-height: 1.45;
}

body {
  max-width: 960px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
}

/* Headers — still boxy and serious */
h1, h2, h3 {
  font-weight: normal;
  letter-spacing: 0.03em;
  color: black;
  margin-bottom: 0.8em;
}

h1 {
  font-size: 2.4rem;
  border-bottom: 3px solid var(--accent);
  padding-bottom: 0.4rem;
  display: inline-block;
}

h2 {
  font-size: 1.8rem;
  border-left: 6px solid var(--accent);
  padding-left: 0.9rem;
}

/* Links — red TrackPoint style, now on white */
a {
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px dotted var(--accent);
  transition: all 0.12s ease;
}

a:hover,
a:focus {
  color: var(--highlight);
  border-bottom-style: solid;
  background: rgba(230, 57, 45, 0.07);
}

/* Buttons — sturdy, now light with red pop */
button,
.button,
input[type="submit"],
input[type="button"] {
  background: var(--surface);
  color: black;
  border: 2px solid var(--border);
  padding: 0.6rem 1.2rem;
  font-family: inherit;
  font-size: 1rem;
  cursor: pointer;
  transition: all 0.13s ease;
}

button:hover,
.button:hover,
input[type="submit"]:hover {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
}

/* Red "TrackPoint" variant — pops even more on white */
.btn-red {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
}

.btn-red:hover {
  background: var(--highlight);
  border-color: var(--highlight);
}

/* Cards / panels — clean white with subtle border */
.card,
section,
article {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 1.5rem;
  margin: 1.8rem 0;
  border-radius: 0;
}

/* Code / pre — still retro, but light-background friendly */
pre, code {
  background: #f0f0f0;
  color: #111;
  padding: 1rem;
  border: 1px solid #d0d0d0;
  font-family: inherit;
  overflow-x: auto;
}

/* Footer — understated, like a model number stamp */
footer {
  margin-top: 4rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
  color: var(--text-dim);
  font-size: 0.9rem;
  text-align: center;
}

/* Focus — still precise red outline */
:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}
